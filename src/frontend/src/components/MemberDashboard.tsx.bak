function AnimatedStatCard({
  stat,
  delay,
}: {
  stat: {
    label: string;
    value: number;
    icon: string;
    color: string;
    glow: string;
  };
  delay: number;
}) {
  const [displayed, setDisplayed] = useState(0);
  useEffect(() => {
    const start = Date.now();
    const duration = 900;
    const tick = () => {
      const elapsed = Date.now() - start - delay;
      if (elapsed < 0) {
        requestAnimationFrame(tick);
        return;
      }
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - (1 - progress) ** 3;
      setDisplayed(Math.round(stat.value * eased));
      if (progress < 1) requestAnimationFrame(tick);
    };
    const raf = requestAnimationFrame(tick);
    return () => cancelAnimationFrame(raf);
  }, [stat.value, delay]);

  return (
    <div
      className="rounded-xl p-4 border border-gray-200 text-center"
      style={{
        background: "#ffffff",
        boxShadow: `0 0 16px ${stat.glow}`,
      }}
      data-ocid={`stats.${stat.label.toLowerCase().replace(/ /g, "_")}.card`}
    >
      <div className="text-2xl mb-1">{stat.icon}</div>
      <div
        className="text-xl font-bold"
        style={{ color: stat.color, textShadow: `0 0 10px ${stat.color}80` }}
      >
        {displayed.toLocaleString()}
      </div>
      <div className="text-xs text-gray-500 mt-0.5">{stat.label}</div>
    </div>
  );
}

// ---- Tasks Panel ----
const TASKS_KEY = "clawpro_tasks";
interface Task {
  id: string;
  text: string;
  done: boolean;
  createdAt: number;
}

function TasksPanel() {
  const [tasks, setTasks] = useState<Task[]>(() => {
    try {
      return JSON.parse(localStorage.getItem(TASKS_KEY) ?? "[]");
    } catch {
      return [];
    }
  });
  const [input, setInput] = useState("");

  const save = (updated: Task[]) => {
    setTasks(updated);
    localStorage.setItem(TASKS_KEY, JSON.stringify(updated));
  };

  const addTask = () => {
    if (!input.trim()) return;
    save([
      ...tasks,
      {
        id: Date.now().toString(),
        text: input.trim(),
        done: false,
        createdAt: Date.now(),
      },
    ]);
    setInput("");
    toast.success("Task added!");
  };

  const toggle = (id: string) =>
    save(tasks.map((t) => (t.id === id ? { ...t, done: !t.done } : t)));
  const remove = (id: string) => save(tasks.filter((t) => t.id !== id));

  const pending = tasks.filter((t) => !t.done);
  const done = tasks.filter((t) => t.done);

  return (
    <div className="p-6 space-y-5">
      <div className="flex items-center gap-3">
        <div
          className="w-10 h-10 rounded-xl flex items-center justify-center"
          style={{
            background: "oklch(0.12 0.04 180)",
            boxShadow: "0 0 16px rgba(20,184,166,0.3)",
          }}
        >
          <CheckSquare2 className="w-5 h-5 text-teal-400" />
        </div>
        <div>
          <h2 className="font-semibold">Task Manager</h2>
          <p className="text-xs text-gray-500">
            {pending.length} pending · {done.length} done
          </p>
        </div>
      </div>

      <div
        className="flex gap-2 p-3 rounded-xl border border-teal-500/20"
        style={{ background: "oklch(0.09 0.015 180)" }}
      >
        <input
          type="text"
          className="flex-1 bg-transparent text-sm text-foreground placeholder:text-gray-500 outline-none"
          placeholder="Add a new task..."
          value={input}
          onChange={(e) => setInput(e.target.value)}
          onKeyDown={(e) => e.key === "Enter" && addTask()}
          data-ocid="tasks.input"
        />
        <button
          type="button"
          onClick={addTask}
          className="px-3 py-1.5 rounded-lg text-xs font-medium text-teal-900 transition-all"
          style={{
            background: "linear-gradient(135deg, #2dd4bf, #0d9488)",
            boxShadow: "0 0 12px rgba(20,184,166,0.4)",
          }}
          data-ocid="tasks.add_button"
        >
          <Plus className="w-3.5 h-3.5" />
        </button>
      </div>

      {tasks.length === 0 && (
        <div
          className="text-center py-8 text-gray-500 text-sm"
          data-ocid="tasks.empty_state"
        >
          No tasks yet. Add one above!
        </div>
      )}

      <div className="space-y-2">
        <AnimatePresence>
          {pending.map((task, i) => (
            <motion.div
              key={task.id}
              initial={{ opacity: 0, x: -16 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: 16 }}
              transition={{ duration: 0.15 }}
              className="flex items-center gap-3 p-3 rounded-xl border border-teal-500/15 hover:border-teal-500/30 transition-colors"
              style={{ background: "#f8fafc" }}
              data-ocid={`tasks.item.${i + 1}`}
            >
              <button
                type="button"
                onClick={() => toggle(task.id)}
                className="w-5 h-5 rounded border-2 border-teal-500/50 hover:border-teal-400 transition-colors flex items-center justify-center flex-shrink-0"
                data-ocid={`tasks.checkbox.${i + 1}`}
              >
                {task.done && (
                  <Circle className="w-2 h-2 fill-teal-400 text-teal-400" />
                )}
              </button>
              <span className="flex-1 text-sm">{task.text}</span>
              <button
                type="button"
                onClick={() => remove(task.id)}
                className="p-1 text-gray-500 hover:text-red-400 transition-colors"
                data-ocid={`tasks.delete_button.${i + 1}`}
              >
                <Trash2 className="w-3.5 h-3.5" />
              </button>
            </motion.div>
          ))}
        </AnimatePresence>
      </div>

      {done.length > 0 && (
        <div className="space-y-1.5">
          <p className="text-xs text-gray-500 uppercase tracking-wider font-medium">
            Completed
          </p>
          <AnimatePresence>
            {done.map((task, i) => (
              <motion.div
                key={task.id}
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0 }}
                className="flex items-center gap-3 p-3 rounded-xl border border-gray-100 opacity-60"
                style={{ background: "oklch(0.08 0.008 240)" }}
                data-ocid={`tasks.done.item.${i + 1}`}
              >
                <div className="w-5 h-5 rounded border-2 border-teal-400/40 flex items-center justify-center flex-shrink-0">
                  <Circle className="w-2 h-2 fill-teal-400 text-teal-400" />
                </div>
                <span className="flex-1 text-sm line-through text-gray-500">
                  {task.text}
                </span>
                <button
                  type="button"
                  onClick={() => remove(task.id)}
                  className="p-1 text-gray-500 hover:text-red-400 transition-colors"
                >
                  <Trash2 className="w-3.5 h-3.5" />
                </button>
              </motion.div>
            ))}
          </AnimatePresence>
        </div>
      )}
    </div>
  );
}

// ---- System Status Panel ----
function StatusPanel() {
  const [statuses, setStatuses] = useState([
    {
      name: "OpenClaw.ai",
      url: "https://openclaw.ai",
      status: "checking" as "online" | "offline" | "slow" | "checking",
      latency: 0,
      color: "#ef4444",
    },
    {
      name: "ChatGPT / OpenAI",
      url: "https://status.openai.com",
      status: "checking" as "online" | "offline" | "slow" | "checking",
      latency: 0,
      color: "#10b981",
    },
    {
      name: "Gemini AI",
      url: "https://ai.google.dev",
      status: "checking" as "online" | "offline" | "slow" | "checking",
      latency: 0,
      color: "#3b82f6",
    },
    {
      name: "CoinGecko API",
      url: "https://api.coingecko.com/api/v3/ping",
      status: "checking" as "online" | "offline" | "slow" | "checking",
      latency: 0,
      color: "#f59e0b",
    },
    {
      name: "GitHub API",
      url: "https://api.github.com",
      status: "checking" as "online" | "offline" | "slow" | "checking",
      latency: 0,
      color: "#8b5cf6",
    },
    {
      name: "ICP Network",
      url: "https://ic0.app",
      status: "online" as "online" | "offline" | "slow" | "checking",
      latency: 12,
      color: "#06b6d4",
    },
  ]);
  const [lastChecked, setLastChecked] = useState<Date | null>(null);
  const [checking, setChecking] = useState(false);

  const checkAll = async () => {
    setChecking(true);
    const results = await Promise.all(
      statuses.map(async (s) => {
        const start = Date.now();
        try {
          await fetch(s.url, {
            method: "HEAD",
            mode: "no-cors",
            signal: AbortSignal.timeout(4000),
          });
          const lat = Date.now() - start;
          return {
            ...s,
            status: lat > 2000 ? "slow" : ("online" as "online" | "slow"),
            latency: lat,
          };
        } catch {
          return { ...s, status: "offline" as const, latency: 0 };
        }
      }),
    );
    setStatuses(results);
    setLastChecked(new Date());
    setChecking(false);
  };

  // biome-ignore lint/correctness/useExhaustiveDependencies: intentional
  useEffect(() => {
    checkAll();
  }, []);

  const dotColor = (s: string) =>
    s === "online"
      ? "#22c55e"
      : s === "slow"
        ? "#f59e0b"
        : s === "offline"
          ? "#ef4444"
          : "#94a3b8";
  const dotLabel = (s: string) =>
    s === "online"
      ? "Online"
      : s === "slow"
        ? "Slow"
        : s === "offline"
          ? "Offline"
          : "Checking...";

  const allOnline = statuses.every((s) => s.status === "online");

  return (
    <div className="p-6 space-y-5">
      <div className="flex items-center justify-between">
        <div className="flex items-center gap-3">
          <div
            className="w-10 h-10 rounded-xl flex items-center justify-center"
            style={{
              background: "oklch(0.13 0.04 50)",
              boxShadow: "0 0 16px rgba(249,115,22,0.3)",
            }}
          >
            <Cpu className="w-5 h-5 text-orange-400" />
          </div>
          <div>
            <h2 className="font-semibold">System Status</h2>
            <p className="text-xs text-gray-500">
              {lastChecked
                ? `Last checked: ${lastChecked.toLocaleTimeString()}`
                : "Checking..."}
            </p>
          </div>
        </div>
        <button
          type="button"
          onClick={checkAll}
          disabled={checking}
          className="text-xs text-orange-400 hover:text-orange-300 flex items-center gap-1 transition-colors"
          data-ocid="status.refresh.button"
        >
          {checking ? (
            <Loader2 className="w-3 h-3 animate-spin" />
          ) : (
            <Zap className="w-3 h-3" />
          )}
          {checking ? "Checking..." : "Recheck"}
        </button>
      </div>

      <div
        className="rounded-xl p-3 border flex items-center gap-2"
        style={{
          background: allOnline
            ? "oklch(0.11 0.03 140)"
            : "oklch(0.11 0.03 30)",
          borderColor: allOnline
            ? "rgba(34,197,94,0.3)"
            : "rgba(239,68,68,0.3)",
          boxShadow: allOnline
            ? "0 0 20px rgba(34,197,94,0.12)"
            : "0 0 20px rgba(239,68,68,0.12)",
        }}
      >
        <div
          className="w-3 h-3 rounded-full flex-shrink-0"
          style={{
            background: allOnline ? "#22c55e" : "#f59e0b",
            boxShadow: `0 0 8px ${allOnline ? "#22c55e" : "#f59e0b"}`,
            animation: "pulse 2s infinite",
          }}
        />
        <span
          className="text-sm font-medium"
          style={{ color: allOnline ? "#4ade80" : "#fbbf24" }}
        >
          {allOnline
            ? "All systems operational"
            : "Some services may be degraded"}
        </span>
      </div>

      <div className="space-y-2">
        {statuses.map((s, i) => (
          <div
            key={s.name}
            className="flex items-center gap-3 p-3.5 rounded-xl border border-white/8 hover:border-white/15 transition-colors"
            style={{ background: "#f8fafc" }}
            data-ocid={`status.item.${i + 1}`}
          >
            <div
              className="w-3 h-3 rounded-full flex-shrink-0"
              style={{
                background: dotColor(s.status),
                boxShadow: `0 0 6px ${dotColor(s.status)}`,
                animation:
                  s.status === "checking"
                    ? "pulse 1s infinite"
                    : s.status === "online"
                      ? "pulse 3s infinite"
                      : "none",
              }}
            />
            <div className="flex-1">
              <div className="flex items-center justify-between">
                <span className="text-sm font-medium">{s.name}</span>
                <span
                  className="text-xs font-medium"
                  style={{ color: dotColor(s.status) }}
                >
                  {dotLabel(s.status)}
                </span>
              </div>
              {s.latency > 0 && (
                <div className="flex items-center gap-1 mt-0.5">
                  <div
                    className="h-1 rounded-full"
                    style={{
                      width: `${Math.min(s.latency / 30, 100)}%`,
                      maxWidth: "120px",
                      background:
                        s.latency < 500
                          ? "#22c55e"
                          : s.latency < 1500
                            ? "#f59e0b"
                            : "#ef4444",
                    }}
                  />
                  <span className="text-[10px] text-gray-500">
                    {s.latency}ms
                  </span>
                </div>
              )}
            </div>
            <div
              className="w-2 h-2 rounded-full flex-shrink-0"
              style={{ background: s.color, opacity: 0.7 }}
            />
          </div>
        ))}
      </div>
    </div>
  );
}

